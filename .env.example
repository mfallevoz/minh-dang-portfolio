# Copy to .env.local and set your own values.

# Password for the /admin page.
ADMIN_PASSWORD=changeme

# Public site URL (for SEO: canonical, sitemap, Open Graph, structured data).
# On Vercel it falls back to the auto-provided production URL, but set this to
# your real/custom domain once you have one. No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://minhdang.com

# Set automatically by Vercel when you add Blob storage (do NOT set locally
# unless you want to use Blob in dev). When present, uploads go to Vercel Blob;
# otherwise they are saved to public/videos/ on the local filesystem.
# BLOB_READ_WRITE_TOKEN=
